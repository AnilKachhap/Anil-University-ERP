@using Microsoft.AspNetCore.Identity
@using AnilUniversity.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Anil University ERP</title>
    <link rel="icon" type="image/x-icon" href="~/Images/favicon.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

            body {
                margin: 0;
                font-family: 'Poppins',sans-serif;
                background: #f1f5f9;
            }


            /* SIDEBAR */

            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                width: 260px;
                height: 100vh;
                background: linear-gradient(180deg,#0f172a,#1e293b);
                overflow-y: auto;
                box-shadow: 5px 0 25px rgba(0,0,0,.2);
                transition: .3s;
                z-index: 1000;
            }


            .sidebar-logo {
                padding: 30px 15px;
                text-align: center;
                border-bottom: 1px solid rgba(255,255,255,.15);
            }


                .sidebar-logo i {
                    font-size: 55px;
                    color: #38bdf8;
                }


                .sidebar-logo h3 {
                    color: white;
                    font-size: 24px;
                    font-weight: 700;
                }


                .sidebar-logo small {
                    color: #cbd5e1;
                }



            /* MENU */

            .nav-item {
                display: flex;
                align-items: center;
                gap: 15px;
                margin: 10px 15px;
                padding: 13px 18px;
                border-radius: 12px;
                color: #cbd5e1;
                text-decoration: none;
                font-size: 15px;
                transition: .3s;
            }


                .nav-item i {
                    width: 25px;
                    font-size: 18px;
                }



                .nav-item:hover {
                    background: #2563eb;
                    color: white;
                    transform: translateX(5px);
                }



                /* CURRENT PAGE */

                .nav-item.active {
                    background: #2563eb;
                    color: white;
                    box-shadow: 0 5px 15px rgba(37,99,235,.4);
                }



            /* TOPBAR */


            .topbar {
                margin-left: 260px;
                height: 75px;
                background: white;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 30px;
                box-shadow: 0 3px 15px rgba(0,0,0,.08);
                position: sticky;
                top: 0;
                z-index: 999;
            }



            .content {
                margin-left: 260px;
                padding: 30px;
                min-height: calc(100vh - 130px);
            }



            .avatar {
                width: 45px;
                height: 45px;
                border-radius: 50%;
                background: linear-gradient(135deg,#2563eb,#06b6d4);
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-weight: 700;
            }



            /* FOOTER */


            .footer {
                margin-left: 260px;
                padding: 15px;
                background: #0f172a;
                color: white;
                text-align: center;
            }



            /* MOBILE */


            #menuBtn {
                display: none;
            }



            @@media(max-width:991px) {


                .sidebar {
                    left: -260px;
                }


                    .sidebar.show {
                        left: 0;
                    }



                .topbar,
                .content,
                .footer {
                    margin-left: 0;
                }



                #menuBtn {
                    display: block;
                }


                .search-box {
                    display: none;
                }
            }

    </style>

</head>


<body>


    <aside class="sidebar">


        <div class="sidebar-logo">

            <i class="fa-solid fa-graduation-cap"></i>

            <h3>ANIL UNIVERSITY</h3>

            <small>ERP Management System</small>

        </div>



        @{

            var controller =
            ViewContext.RouteData.Values["Controller"]?.ToString();

        }


        <a class="nav-item @(controller == "Dashboard" ? "active" : "")"
           asp-controller="Dashboard"
           asp-action="Index">

            <i class="fa fa-house"></i>
            Dashboard

        </a>


        <a class="nav-item @(controller == "Student" ? "active" : "")"
           asp-controller="Student"
           asp-action="Index">

            <i class="fa fa-users"></i>
            Students

        </a>


        <a class="nav-item @(controller == "Course" ? "active" : "")"
           asp-controller="Course"
           asp-action="Index">

            <i class="fa fa-book"></i>
            Courses

        </a>


        <a class="nav-item @(controller == "Attendance" ? "active" : "")"
           asp-controller="Attendance"
           asp-action="Index">

            <i class="fa fa-calendar-check"></i>
            Attendance

        </a>


        <a class="nav-item @(controller == "Payment" ? "active" : "")"
           asp-controller="Payment"
           asp-action="Index">

            <i class="fa fa-wallet"></i>
            Payments

        </a>



        <a class="nav-item @(controller == "Notification" ? "active" : "")"
           asp-controller="Notification"
           asp-action="Index">

            <i class="fa fa-bell"></i>
            Notifications

        </a>


    </aside>




    <header class="topbar">


        <button class="btn btn-primary"
                id="menuBtn">

            <i class="fa fa-bars"></i>

        </button>



        <div>

            <h4 class="mb-0">

                @ViewData["Title"]

            </h4>

            <small>
                Welcome to Anil University ERP
            </small>

        </div>




        <div class="d-flex align-items-center gap-3">


            <input class="form-control rounded-pill search-box"
                   placeholder="Search Student, Course..."
                   style="width:250px">


            @{

                string username =
                User.Identity?.Name ?? "Admin";

                string firstLetter =
                username.Substring(0, 1).ToUpper();

            }



            <div class="avatar">

                @firstLetter

            </div>



            <div>

                <strong>
                    @username
                </strong>

                <br>

                <small>
                    Administrator
                </small>

            </div>



            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  method="post">

                <button class="btn btn-outline-danger btn-sm">

                    Logout

                </button>


            </form>


        </div>


    </header>




    <main class="content">

        @RenderBody()

    </main>




    <footer class="footer">

        © 2026 Anil University ERP | Developed by Anil Kachhap

    </footer>




    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        document.getElementById("menuBtn")
        ?.addEventListener("click", function () {
        document.querySelector(".sidebar").classList.toggle("show");
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
  


   


</body>

</html>