@using Microsoft.AspNetCore.Identity
@using AnilUniversity.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Anil University</title>
    <link rel="icon" type="image/x-icon" href="~/Images/favicon.ico">
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark shadow sticky-top"
         style="background:linear-gradient(90deg,#283593,#3949ab,#5c6bc0);">

        <div class="container">

            <a class="navbar-brand fw-bold fs-4"
               asp-controller="Home"
               asp-action="Index">

                 Anil University Of Technology 

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menu">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="menu">

                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">

                        <a class="nav-link px-3"
                           asp-controller="Home"
                           asp-action="Index">

                            <i class="fa fa-house"></i>
                            Home

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3"
                           asp-controller="Course"
                           asp-action="PublicCourses">

                            <i class="fa fa-book-open"></i>
                            Courses

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link px-3"
                           asp-controller="Student"
                           asp-action="Register">

                            <i class="fa fa-user-plus"></i>
                            Admission

                        </a>

                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="About">
                            About
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Contact">
                            Contact
                        </a>
                    </li>

                </ul>

                <ul class="navbar-nav">

                    @if (SignInManager.IsSignedIn(User))
                    {
                        var user = await UserManager.GetUserAsync(User);
                        var roles = await UserManager.GetRolesAsync(user);

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle fw-bold text-white"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">

                                <i class="fa-solid fa-circle-user"></i>

                                @user.Email

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow">

                                @if (roles.Contains("Admin"))
                                {
                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Dashboard"
                                           asp-action="Index">

                                            <i class="fa fa-chart-line"></i>

                                            Admin Dashboard

                                        </a>

                                    </li>
                                }

                                @if (roles.Contains("Student"))
                                {
                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="StudentPortal"
                                           asp-action="Dashboard">

                                            <i class="fa fa-user-graduate"></i>

                                            Student Dashboard

                                        </a>

                                    </li>
                                }

                                <li>
                                    <hr class="dropdown-divider" />
                                </li>

                                <li>

                                    <form asp-area="Identity"
                                          asp-page="/Account/Logout"
                                          method="post">

                                        <button class="dropdown-item text-danger">

                                            <i class="fa fa-right-from-bracket"></i>

                                            Logout

                                        </button>

                                    </form>

                                </li>

                            </ul>

                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2">

                            <a class="btn btn-outline-light rounded-pill px-4"
                               asp-controller="Student"
                               asp-action="Register">

                                Apply Now

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="btn btn-warning rounded-pill px-4 fw-bold"
                               asp-area="Identity"
                               asp-page="/Account/Login">

                                <i class="fa-solid fa-right-to-bracket"></i>

                                Login

                            </a>

                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <main class="container py-4">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm">

                @TempData["Success"]

                <button class="btn-close"
                        data-bs-dismiss="alert"></button>

            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm">

                @TempData["Error"]

                <button class="btn-close"
                        data-bs-dismiss="alert"></button>

            </div>
        }

        @RenderBody()

    </main>

    <footer class="mt-5 text-white"
            style="background:#1f2937;">

        <div class="container py-5">

            <div class="row">

                <div class="col-md-4">

                    <h4 class="fw-bold">

                         Anil University Of Technology

                    </h4>

                    <p class="text-light">

                        Empowering students through quality education,
                        innovation and excellence.

                    </p>

                </div>

                <div class="col-md-4">

                    <h5>Quick Links</h5>

                    <ul class="list-unstyled">

                        <li>
                            <a asp-controller="Home"
                               asp-action="Index"
                               class="text-white text-decoration-none">

                                Home

                            </a>
                        </li>

                        <li>
                            <a asp-controller="Course"
                               asp-action="PublicCourses"
                               class="text-white text-decoration-none">

                                Courses

                            </a>
                        </li>

                        <li>
                            <a asp-controller="Student"
                               asp-action="Register"
                               class="text-white text-decoration-none">

                                Admission

                            </a>
                        </li>

                    </ul>

                </div>

                <div class="col-md-4">

                    <h5>Contact</h5>

                    <p class="mb-1">

                        📧 anilkachhapmca@gmail.com

                    </p>

                    <p class="mb-1">

                        📍 India

                    </p>

                </div>

            </div>

            <hr class="border-secondary" />

            <div class="text-center">

                © 2026 <strong>Anil University Of Technology</strong> |
                All Rights Reserved

            </div>

        </div>

    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
