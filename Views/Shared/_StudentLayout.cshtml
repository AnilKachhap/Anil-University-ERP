@using Microsoft.AspNetCore.Identity
@using AnilUniversity.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Student Portal</title>
    <link rel="icon" type="image/x-icon" href="~/Images/favicon.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

</head>

<body style="background:#f5f7fb;">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">

        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="StudentPortal"
               asp-action="Dashboard">

                🎓 Student Portal

            </a>

            <button class="navbar-toggler"
                    data-bs-toggle="collapse"
                    data-bs-target="#menu">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="menu">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="StudentPortal"
                           asp-action="Dashboard">

                            <i class="fa-solid fa-house"></i>
                            Dashboard

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="StudentPortal"
                           asp-action="MyProfile">

                            <i class="fa-solid fa-user"></i>
                            My Profile

                        </a>
                    </li>
                 

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="StudentPortal"
                           asp-action="EditProfile">

                            <i class="fa-solid fa-user-pen"></i>
                            Edit Profile

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="StudentPortal"
                           asp-action="MyDocuments">

                            <i class="fa-solid fa-folder"></i>
                            Documents

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="StudentPortal"
                           asp-action="MyAttendance">

                            <i class="fa-solid fa-calendar-check"></i>
                            Attendance

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="StudentPortal"
                           asp-action="MyPayments">

                            <i class="fa-solid fa-credit-card"></i>
                            Payments

                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="StudentPortal"
                           asp-action="MyIdCard">

                            <i class="fa-solid fa-id-card"></i>
                            ID Card

                        </a>
                    </li>

                </ul>

                <ul class="navbar-nav">

                    @if (SignInManager.IsSignedIn(User))
                    {
                        var user = await UserManager.GetUserAsync(User);

                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle text-warning fw-bold"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown">

                                @if (!string.IsNullOrEmpty(ViewBag.StudentPhoto))
                                {
                                    <img src="@ViewBag.StudentPhoto"
                                         style="width:35px;height:35px;border-radius:50%;object-fit:cover;margin-right:6px;" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-circle-user fs-4 me-2"></i>
                                }

                                @ViewBag.StudentName

                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li class="px-3 py-2">

                                    <strong>@ViewBag.StudentName</strong><br />

                                    <small class="text-muted">
                                        @ViewBag.StudentEmail
                                    </small>

                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="StudentPortal"
                                       asp-action="Dashboard">
                                        <i class="fa fa-house"></i> Dashboard
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="StudentPortal"
                                       asp-action="MyProfile">
                                        <i class="fa fa-user"></i> My Profile
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="StudentPortal"
                                       asp-action="MyDocuments">
                                        <i class="fa fa-folder"></i> My Documents
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Identity"
                                       asp-page="/Account/Manage/ChangePassword">
                                        <i class="fa fa-key"></i> Change Password
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li>
                                    <form asp-area="Identity"
                                          asp-page="/Account/Logout"
                                          method="post">

                                        <button type="submit"
                                                class="dropdown-item text-danger">

                                            <i class="fa fa-right-from-bracket"></i>
                                            Logout

                                        </button>

                                    </form>
                                </li>

                            </ul>

                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <div class="container mt-4">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">

                @TempData["Success"]

                <button class="btn-close"
                        data-bs-dismiss="alert"></button>

            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">

                @TempData["Error"]

                <button class="btn-close"
                        data-bs-dismiss="alert"></button>

            </div>
        }

        @RenderBody()

    </div>

    <footer class="bg-dark text-white mt-5">

        <div class="container text-center py-3">

            <h5>Anil University</h5>

            <div>Student Portal</div>

            <small>

                © 2026 All Rights Reserved

            </small>

        </div>

    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>