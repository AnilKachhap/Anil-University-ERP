@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model IEnumerable<AnilUniversity.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-primary">
                📚 Available Courses
            </h2>

            <p class="text-muted">
                Manage university courses and admission seats
            </p>
        </div>


        <a asp-action="Create" class="btn btn-primary btn-lg shadow">
            <i class="bi bi-plus-circle"></i>
            Add Course
        </a>

    </div>


    <div class="row g-4">


        @foreach (var item in Model)
        {

            var progress = 0;

            if (item.TotalSeats > 0)
            {
                progress = (item.FilledSeats * 100) / item.TotalSeats;
            }


            <div class="col-md-6 col-lg-4">


                <div class="card h-100 shadow border-0 course-card">


                    <div class="card-body">


                        <div class="text-center mb-3">

                            <div class="course-icon">
                                🎓
                            </div>


                            <h4 class="fw-bold mt-3">
                                @item.CourseName
                            </h4>

                        </div>



                        <div class="d-flex justify-content-between mb-3">


                            <span class="badge bg-info text-dark p-2">

                                ⏳ @item.Duration

                            </span>


                            <span class="badge bg-success p-2">

                                💰 ₹ @item.Fees

                            </span>


                        </div>




                        <hr />



                        <div class="mb-2">

                            <div class="d-flex justify-content-between">

                                <span>
                                    👥 Seats Filled
                                </span>

                                <strong>
                                    @item.FilledSeats / @item.TotalSeats
                                </strong>

                            </div>



                            <div class="progress mt-2">

                                <div class="progress-bar"
                                     role="progressbar"
                                     style="width:@progress%">

                                    @progress%

                                </div>

                            </div>

                        </div>




                        <div class="mt-3">


                            @if (item.AvailableSeats > 0)
                            {

                                <span class="badge bg-success">

                                    ✅ @item.AvailableSeats Seats Available

                                </span>

                            }
                            else
                            {

                                <span class="badge bg-danger">

                                    ❌ Admission Closed

                                </span>

                            }



                            @if (item.IsActive)
                            {

                                <span class="badge bg-primary ms-2">

                                    Active

                                </span>

                            }
                            else
                            {

                                <span class="badge bg-secondary ms-2">

                                    Inactive

                                </span>

                            }


                        </div>



                    </div>




                    <div class="card-footer bg-white border-0">


                        <div class="d-grid gap-2">


                            <a asp-controller="Student"
                               asp-action="Register"
                               asp-route-courseId="@item.CourseId"
                               class="btn btn-success">

                                🚀 Apply Now

                            </a>



                            <div class="btn-group">


                                <a asp-action="Edit"
                                   asp-route-id="@item.CourseId"
                                   class="btn btn-warning btn-sm">

                                    ✏ Edit

                                </a>



                                <a asp-action="ToggleStatus"
                                   asp-route-id="@item.CourseId"
                                   class="btn btn-secondary btn-sm">

                                    @(item.IsActive ? "Deactivate" : "Activate")

                                </a>



                                <a asp-action="Delete"
                                   asp-route-id="@item.CourseId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete this course?')">

                                    🗑 Delete

                                </a>


                            </div>


                        </div>


                    </div>


                </div>


            </div>


        }


    </div>


</div>



<style>

    .course-card {
        transition: 0.3s;
        border-radius: 20px;
    }


        .course-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important;
        }



    .course-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #e8f1ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin: auto;
    }


    .progress {
        height: 10px;
        border-radius: 10px;
    }

</style>