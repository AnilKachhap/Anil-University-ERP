@{
    ViewData["Title"] = "Home";
}
<style>

    .hero-section {
        background: url('/images/university.jpg');
        background-size: cover;
        background-position: center;
        height: 600px;
        border-radius: 0 0 30px 30px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,.3);
    }

    .hero-overlay {
        background: linear-gradient(rgba(13,110,253,.75),rgba(0,0,0,.65));
        height: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero-section h1 {
        font-size: 65px;
        font-weight: bold;
        text-shadow: 3px 3px 10px black;
    }

    .hero-section p {
        font-size: 22px;
    }

    .hero-section .btn {
        padding: 12px 35px;
        font-size: 20px;
        border-radius: 30px;
    }

    .card {
        transition: .4s;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,.25);
        }

</style>
<div class="container-fluid p-0">

    <!-- Hero Section -->
    <div class="hero-section text-white">

        <div class="hero-overlay">

            <div class="container text-center py-5">

                <h1 class="display-3 fw-bold">
                    ANIL UNIVERSITY
                </h1>

                <p class="lead">
                    Online Admission & Student Management Portal
                </p>

                <p>
                    Admissions Open for 2026-27 Session
                </p>

                <a asp-controller="Student"
                   asp-action="Register"
                   class="btn btn-warning btn-lg me-2">

                    Apply Now

                </a>

                <a asp-controller="Course"
                   asp-action="PublicCourses"
                   class="btn btn-light btn-lg">

                    Explore Courses

                </a>

            </div>

        </div>

    </div>

      

    </div>

