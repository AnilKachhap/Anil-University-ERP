@model AnilUniversity.Models.Student

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admission Form</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <script>
            function PrintPage() {
                window.print();
            }
    </script>
</head>

<body class="container mt-4">

    <h2 class="text-center">
        ANIL UNIVERSITY
    </h2>

    <hr />

    <table class="table table-bordered">

        <tr>
            <th>Application No</th>
            <td>@Model.ApplicationNo</td>
        </tr>

        <tr>
            <th>Name</th>
            <td>@Model.FullName</td>
        </tr>

        <tr>
            <th>Father Name</th>
            <td>@Model.FatherName</td>
        </tr>

        <tr>
            <th>Mother Name</th>
            <td>@Model.MotherName</td>
        </tr>

        <tr>
            <th>Course</th>
            <td>@Model.Course?.CourseName</td>
        </tr>

        <tr>
            <th>Mobile</th>
            <td>@Model.Mobile</td>
        </tr>

        <tr>
            <th>Email</th>
            <td>@Model.Email</td>
        </tr>

    </table>

    <button onclick="PrintPage()" class="btn btn-success">
        Print
    </button>

</body>
</html>