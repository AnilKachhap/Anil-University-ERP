@model AnilUniversity.Models.Student

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <title>Student ID Card</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>

            body {
                background: #edf2f7;
                font-family: Arial, Helvetica, sans-serif;
            }

            .id-card {
                width: 390px;
                margin: 30px auto;
                background: white;
                border-radius: 18px;
                overflow: hidden;
                border: 3px solid #0d6efd;
                box-shadow: 0 10px 25px rgba(0,0,0,.25);
            }

            .header {
                background: linear-gradient(90deg,#0d6efd,#003f9e);
                color: white;
                text-align: center;
                padding: 18px;
            }

                .header img {
                    background: white;
                    border-radius: 50%;
                    padding: 5px;
                }

            .photo {
                width: 125px;
                height: 145px;
                object-fit: cover;
                border: 3px solid #0d6efd;
                border-radius: 8px;
            }

            .info-table td {
                padding: 6px;
                font-size: 15px;
            }

                .info-table td:first-child {
                    font-weight: bold;
                    width: 40%;
                }

            .footer {
                background: #0d6efd;
                color: white;
                text-align: center;
                padding: 10px;
                font-size: 13px;
            }

            .signature {
                width: 90px;
            }

            @@media print {

                .print-btn {
                    display: none;
                }

                body {
                    background: white;
                }

                .id-card {
                    margin: 0;
                    box-shadow: none;
                }
            }

    </style>

</head>

<body>

    <div class="id-card">

        <div class="header">

            <img src="@Url.Content("~/Images/logo.png")"
                 width="65"
                 class="mb-2" />

            <h3 class="mb-0">
                ANIL UNIVERSITY
            </h3>

            <small>
                STUDENT IDENTITY CARD
            </small>

        </div>

        <div class="text-center mt-3">

            @if (Model.StudentDocument != null &&
                 !string.IsNullOrEmpty(Model.StudentDocument.PhotoPath))
            {
                <img src="@Url.Content(Model.StudentDocument.PhotoPath)"
                     class="photo" />
            }
            else
            {
                <img src="@Url.Content("~/Images/default-user.png")"
                     class="photo" />
            }

        </div>
        <div class="p-3">

            <table class="table table-borderless info-table">

                <tr>
                    <td>Student ID</td>
                    <td>@Model.StudentCode</td>
                </tr>

                <tr>
                    <td>Name</td>
                    <td>@Model.FullName</td>
                </tr>

                <tr>
                    <td>Application No</td>
                    <td>@Model.ApplicationNo</td>
                </tr>

                <tr>
                    <td>Course</td>
                    <td>@Model.Course?.CourseName</td>
                </tr>

                <tr>
                    <td>Mobile</td>
                    <td>@Model.Mobile</td>
                </tr>

                <tr>
                    <td>Email</td>
                    <td>@Model.Email</td>
                </tr>

                <tr>
                    <td>Status</td>
                    <td>

                        @if (Model.Status == "Approved")
                        {
                            <span class="badge bg-success fs-6">
                                ✔ Approved
                            </span>
                        }
                        else if (Model.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark fs-6">
                                ⏳ Pending
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">
                                ✖ Rejected
                            </span>
                        }

                    </td>
                </tr>

            </table>

        </div>

        <hr />

        <div class="row text-center">

            <div class="col-6">

                <img src="@Url.Action("GenerateQr", "Student", new { id = Model.StudentId })"
                     width="100"
                     height="100" />

                <br />

                <small>
                    Scan To Verify
                </small>

            </div>

            <div class="col-6">

                <img src="@Url.Content("~/Images/principal-sign.jpg")"
                     class="signature" />

                <br />

                <small>
                    Principal Signature
                </small>

            </div>

        </div>

        <div class="footer mt-3">

            <i class="fa-solid fa-circle-check"></i>

            Valid University Identity Card

        </div>

        <div class="text-center mt-3 mb-3 print-btn">

            <button onclick="window.print()"
                    class="btn btn-primary">

                <i class="fa-solid fa-print"></i>

                Print ID Card

            </button>
            <a asp-action="DownloadIdCard"
               asp-route-id="@Model.StudentId"
               class="btn btn-danger">

                <i class="fa-solid fa-file-pdf"></i>

                Download PDF

            </a>

        </div>
       
    </div>

</body>

</html>