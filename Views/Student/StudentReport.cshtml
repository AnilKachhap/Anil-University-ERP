@model IEnumerable<AnilUniversity.Models.Student>

@{
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <title>Student Report</title>

    <style>

            body {
                font-family: Arial;
                font-size: 13px;
            }

            h1 {
                text-align: center;
                margin-bottom: 0;
            }

            h3 {
                text-align: center;
                margin-top: 5px;
                color: #444;
            }

            .report-info {
                margin-top: 20px;
                margin-bottom: 20px;
            }

                .report-info table {
                    border: none;
                }

                .report-info td {
                    border: none;
                    padding: 3px;
                }

            table {
                width: 100%;
                border-collapse: collapse;
            }

            th {
                background: #0d6efd;
                color: white;
            }

            table,
            th,
            td {
                border: 1px solid black;
            }

            th,
            td {
                padding: 8px;
                text-align: center;
            }

            tfoot td {
                font-weight: bold;
            }

            .footer {
                margin-top: 60px;
            }

            .signature {
                width: 250px;
                text-align: center;
                float: right;
            }

    </style>

</head>

<body>

    <h1>Anil University</h1>

    <h3>Student Admission Report</h3>

    <hr />

    <div class="report-info">

        <table>

            <tr>

                <td>
                    <b>Generated On :</b>
                    @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
                </td>

                <td style="text-align:right">
                    <b>Total Students :</b>
                    @Model.Count()
                </td>

            </tr>

        </table>

    </div>

    <table>

        <thead>

            <tr>

                <th>#</th>

                <th>Application No</th>

                <th>Student Name</th>

                <th>Course</th>

                <th>Mobile</th>

                <th>Email</th>

                <th>Status</th>

            </tr>

        </thead>

        <tbody>

            @{

                int sr = 1;

            }

            @foreach (var item in Model)
            {
                <tr>

                    <td>@sr</td>

                    <td>@item.ApplicationNo</td>

                    <td>@item.FullName</td>

                    <td>@item.Course?.CourseName</td>

                    <td>@item.Mobile</td>

                    <td>@item.Email</td>

                    <td>@item.Status</td>

                </tr>

                sr++;
            }

        </tbody>

    </table>

    <div class="footer">

        <div class="signature">

            _______________________

            <br />

            <b>Registrar</b>

            <br />

            Anil University

        </div>

    </div>

</body>

</html>