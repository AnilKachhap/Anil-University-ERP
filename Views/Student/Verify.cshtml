@model AnilUniversity.Models.Student

@{
    ViewData["Title"] = "Student Verification";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-success text-white text-center">
            <h3>Student Verification</h3>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-4 text-center">

                    @if (Model.StudentDocument != null)
                    {
                        <img src="@Model.StudentDocument.PhotoPath"
                             width="180"
                             class="img-thumbnail" />
                    }

                </div>

                <div class="col-md-8">

                    <table class="table table-bordered">

                        <tr>
                            <th>Student Name</th>
                            <td>@Model.FullName</td>
                        </tr>

                        <tr>
                            <th>Application No</th>
                            <td>@Model.ApplicationNo</td>
                        </tr>

                        <tr>
                            <th>Student Code</th>
                            <td>@Model.StudentCode</td>
                        </tr>

                        <tr>
                            <th>Course</th>
                            <td>@Model.Course?.CourseName</td>
                        </tr>

                        <tr>
                            <th>Mobile</th>
                            <td>@Model.Mobile</td>
                        </tr>

                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>

                        <tr>
                            <th>Status</th>
                            <td>

                                @if (Model.Status == "Approved")
                                {
                                    <span class="badge bg-success">
                                        Approved
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        @Model.Status
                                    </span>
                                }

                            </td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>