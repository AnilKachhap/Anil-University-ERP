@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model IEnumerable<AnilUniversity.Models.Student>
@{
    ViewData["Title"] = "Dashboard";
}
<style>

    .stat-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        transition: .35s;
        color: #fff;
        box-shadow: 0 12px 30px rgba(0,0,0,.12);
    }

        .stat-card:hover {
            transform: translateY(-8px) scale(1.02);
        }

    .stat-icon {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        background: rgba(255,255,255,.18);
    }

    .stat-value {
        font-size: 34px;
        font-weight: 700;
        margin-top: 15px;
    }

    .bg-students {
        background: linear-gradient(135deg,#4f46e5,#2563eb);
    }

    .bg-course {
        background: linear-gradient(135deg,#10b981,#059669);
    }

    .bg-pending {
        background: linear-gradient(135deg,#f59e0b,#ea580c);
    }

    .bg-approved {
        background: linear-gradient(135deg,#14b8a6,#0f766e);
    }

    .bg-rejected {
        background: linear-gradient(135deg,#ef4444,#b91c1c);
    }

    .bg-fee {
        background: linear-gradient(135deg,#8b5cf6,#6d28d9);
    }

    .bg-today {
        background: linear-gradient(135deg,#06b6d4,#0284c7);
    }

    .bg-seat {
        background: linear-gradient(135deg,#ec4899,#be185d);
    }

    .section-title {
        font-weight: 700;
        font-size: 24px;
        color: #1f2937;
        margin-bottom: 20px;
    }

    .chart-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

</style>

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold text-primary mb-1">
            <i class="fa-solid fa-gauge-high"></i>
            Admin Dashboard
        </h2>

        <p class="text-muted mb-0">
            Welcome Back, Administrator 👋
        </p>
    </div>

    <div class="text-end">
        <span class="badge bg-success fs-6 px-3 py-2">
            @DateTime.Now.ToString("dddd, dd MMM yyyy")
        </span>
    </div>

</div>

<div class="row mb-4">

    <div class="col-lg-8">

        <div class="card border-0 shadow rounded-4">

            <div class="card-body p-4">

                <span class="badge bg-success mb-3 px-3 py-2">
                    ADMIN PANEL
                </span>

                <h2 class="fw-bold mb-2">
                    Welcome Back 👋
                </h2>

                <p class="text-muted mb-0">
                    Manage students, admissions, courses, fee collection and attendance from one dashboard.
                </p>

            </div>

        </div>

    </div>

    <div class="col-lg-4">

        <div class="card border-0 shadow rounded-4 h-100">

            <div class="card-body d-flex flex-column justify-content-center text-center">

                <h6 class="text-muted">
                    Today
                </h6>

                <h4 class="fw-bold text-primary">
                    @DateTime.Now.ToString("dddd")
                </h4>

                <h5 class="text-secondary">
                    @DateTime.Now.ToString("dd MMM yyyy")
                </h5>

            </div>

        </div>

    </div>

</div>

<div class="row g-4 mb-4">

    <div class="col-lg-4 col-md-6">

        <div class="card stat-card bg-students">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>

                    <small>Total Students</small>

                    <div class="stat-value">@ViewBag.TotalStudents</div>

                </div>

                <div class="stat-icon">

                    <i class="fa-solid fa-user-graduate"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-4 col-md-6">

        <div class="card stat-card bg-course">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>

                    <small>Total Courses</small>

                    <div class="stat-value">@ViewBag.TotalCourses</div>

                </div>

                <div class="stat-icon">

                    <i class="fa-solid fa-book"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-4 col-md-6">

        <div class="card stat-card bg-pending">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>

                    <small>Pending Applications</small>

                    <div class="stat-value">@ViewBag.Pending</div>

                </div>

                <div class="stat-icon">

                    <i class="fa-solid fa-clock"></i>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="row g-4 mb-4">

    <div class="col-md-6">

        <div class="card stat-card bg-approved">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>

                    <small>Approved Students</small>

                    <div class="stat-value">@ViewBag.Approved</div>

                </div>

                <div class="stat-icon">

                    <i class="fa-solid fa-circle-check"></i>

                </div>

            </div>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card stat-card bg-rejected">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>

                    <small>Rejected Students</small>

                    <div class="stat-value">@ViewBag.Rejected</div>

                </div>

                <div class="stat-icon">

                    <i class="fa-solid fa-circle-xmark"></i>

                </div>

            </div>

        </div>

    </div>

</div>


<div class="row g-3 mb-4">

    <div class="col-xl-3 col-md-6">

        <div class="card border-0 shadow-sm rounded-4 h-100">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <small class="text-muted">
                            Today's Collection
                        </small>

                        <h2 class="fw-bold text-primary mt-2">

                            ₹@ViewBag.TodayCollection

                        </h2>

                    </div>

                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">

                        <i class="fa-solid fa-indian-rupee-sign text-primary fs-2"></i>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">

   
        <div class="card border-0 shadow-sm rounded-4 h-100">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <small class="text-muted">
                            Attendance
                        </small>

                        <h2 class="fw-bold text-warning mt-2">

                            @ViewBag.TodayAttendance

                        </h2>

                    </div>

                    <div class="rounded-circle bg-warning bg-opacity-10 p-3">

                        <i class="fa-solid fa-calendar-check text-warning fs-2"></i>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>


<div class="row g-4 mb-5">

    <div class="col-md-4">

        <div class="card border-start border-5 border-primary shadow-sm rounded-4">

            <div class="card-body text-center">

                <h6 class="text-muted">

                    Total Seats

                </h6>

                <h2 class="fw-bold">

                    @ViewBag.TotalSeats

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card border-start border-5 border-success shadow-sm rounded-4">

            <div class="card-body text-center">

                <h6 class="text-muted">

                    Filled Seats

                </h6>

                <h2 class="fw-bold text-success">

                    @ViewBag.FilledSeats

                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card border-start border-5 border-warning shadow-sm rounded-4">

            <div class="card-body text-center">

                <h6 class="text-muted">

                    Available Seats

                </h6>

                <h2 class="fw-bold text-warning">

                    @ViewBag.AvailableSeats

                </h2>

            </div>

        </div>

    </div>

</div>


          <h3 class="section-title">
                    <i class="fa-solid fa-user-graduate text-primary"></i>
                    Recent Applications
                </h3>

                <div class="card chart-card mb-5">

                    <div class="card-body">

                        <table id="studentTable" class="table align-middle table-hover">

                            <thead class="table-light">

                                <tr>

                                    <th>Application</th>
                                    <th>Student</th>
                                    <th>Course</th>
                                    <th>Status</th>
                                    <th class="text-center">Action</th>

                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var item in Model)
                                {
                                    <tr>

                                        <td class="fw-semibold">
                                            @item.ApplicationNo
                                        </td>

                                        <td>
                                            @item.FullName
                                        </td>

                                        <td>
                                            @item.Course?.CourseName
                                        </td>

                                        <td>

                                            @if (item.Status == "Approved")
                                            {
                                                <span class="badge bg-success rounded-pill px-3">
                                                    Approved
                                                </span>
                                            }
                                            else if (item.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill px-3">
                                                    Pending
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger rounded-pill px-3">
                                                    Rejected
                                                </span>
                                            }

                                        </td>

                                        <td class="text-center">

                                            <a asp-controller="Student"
                                               asp-action="Preview"
                                               asp-route-id="@item.StudentId"
                                               class="btn btn-sm btn-primary rounded-pill px-3">

                                                <i class="fa-solid fa-eye"></i>

                                            </a>

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>
<div class="my-5"></div>
<h3>Monthly Student Registrations</h3>
<div class="card chart-card mb-5">

    <div class="card-header bg-white border-0">

        <h5 class="fw-bold mb-0">

            <i class="fa-solid fa-chart-column text-primary"></i>

            Monthly Student Registrations

        </h5>

    </div>

    <div class="card-body">

        <canvas id="studentChart" height="90"></canvas>

    </div>

</div>
<div class="row mt-4">

    <div class="col-md-4">
        <div class="card border-primary">
            <div class="card-body text-center">
                <h6 class="text-uppercase fw-bold mb-3">
                    Today's Admissions
                </h6>
                <h1 class="fw-bold mb-0">@ViewBag.TodayStudents</h1>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-lg rounded-4 bg-success h-100 dashboard-card">
            <div class="card-body text-center">
                <h6 class="text-uppercase fw-bold mb-3">
                    This Month
                </h6>
                <h1 class="fw-bold mb-0">@ViewBag.MonthStudents</h1>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-danger">
            <div class="card-body text-center">
                <h6 class="text-uppercase fw-bold mb-3">
                    This Year
                </h6>
                <h1 class="fw-bold mb-0">@ViewBag.YearStudents</h1>
            </div>
        </div>
    </div>
</div>
<div class="my-5"></div>

<h3>Monthly Fee Collection</h3>

<div class="card chart-card mb-5">

    <div class="card-header bg-white border-0">

        <h5 class="fw-bold">

            <i class="fa-solid fa-indian-rupee-sign text-success"></i>

            Monthly Fee Collection

        </h5>

    </div>

    <div class="card-body">

        <canvas id="feeChart" height="90"></canvas>

    </div>

</div>
<div class="my-5"></div>

<h3>Course Wise Students</h3>

<div class="card chart-card mb-5">

    <div class="card-header bg-white border-0">

        <h5 class="fw-bold">

            <i class="fa-solid fa-chart-pie text-danger"></i>

            Course Wise Students

        </h5>

    </div>

    <div class="card-body">

        <canvas id="courseChart" height="110"></canvas>

    </div>

</div>
<div class="row mt-4">

    <div class="col-md-3">
        <div class="card border-0 shadow-lg rounded-4 bg-danger h-100 dashboard-card">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold mb-3">
                    Total Attendance
                </h6>
                <h1 class="fw-bold mb-0">@ViewBag.TotalAttendance</h1>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-lg rounded-4 bg-success h-100 dashboard-card">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold mb-3">
                    Present
                </h6>
                <h1 class="fw-bold mb-0">@ViewBag.TotalPresent</h1>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-lg rounded-4 bg-danger h-100 dashboard-card">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold mb-3">
                    Absent
                </h6>
                <h1 class="fw-bold mb-0">@ViewBag.TotalAbsent</h1>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-lg rounded-4 bg-warning h-100 dashboard-card">
            <div class="card-body">
                <h6 class="text-uppercase fw-bold mb-3">
                    Today's Attendance
                </h6>
                <h1 class="fw-bold mb-0">@ViewBag.TodayAttendance</h1>
            </div>
        </div>
    </div>

</div>

<h3 class="section-title">

    <i class="fa-solid fa-credit-card text-success"></i>

    Recent Payments

</h3>

<div class="card chart-card">

    <div class="card-body">

        <table class="table table-hover align-middle">

            <thead class="table-light">

                <tr>

                    <th>Student</th>

                    <th>Amount</th>

                    <th>Mode</th>

                    <th>Status</th>

                    <th>Date</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in ViewBag.RecentPayments)
                {

                    <tr>

                        <td>@item.Student.FullName</td>

                        <td class="fw-bold text-success">

                            ₹ @item.Amount

                        </td>

                        <td>

                            <span class="badge bg-info">

                                @item.PaymentMode

                            </span>

                        </td>

                        <td>

                            @if (item.PaymentStatus == "Paid")
                            {
                                <span class="badge bg-success">
                                    Paid
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Failed
                                </span>
                            }

                        </td>

                        <td>

                            @item.PaymentDate.ToString("dd MMM yyyy")

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>
@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $(document).ready(function () {

        // ===========================
        // DataTable
        // ===========================
        $('#studentTable').DataTable({
        responsive: true,
        pageLength: 5,
        searching: true,
        ordering: true,
        paging: true,
        info: true,
        language: {
        search: "Search : ",
        lengthMenu: "Show _MENU_ Entries"
        }
        });

        // ===========================
        // Student Registration Chart
        // ===========================
        const studentCanvas = document.getElementById("studentChart");

        if (studentCanvas) {

        var ctx = studentCanvas.getContext("2d");

        new Chart(ctx, {
        type: 'bar',
        data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
        datasets: [{
        label: 'Student Registrations',
        data: [
        @ViewBag.Jan,
        @ViewBag.Feb,
        @ViewBag.Mar,
        @ViewBag.Apr,
        @ViewBag.May,
        @ViewBag.Jun,
        @ViewBag.Jul,
        @ViewBag.Aug,
        @ViewBag.Sep,
        @ViewBag.Oct,
        @ViewBag.Nov,
        @ViewBag.Dec
        ],
        backgroundColor: 'rgba(54,162,235,0.6)',
        borderColor: 'rgba(54,162,235,1)',
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
        y: {
        beginAtZero: true
        }
        }
        }
        });

        }

        // ===========================
        // Fee Collection Chart
        // ===========================
        const feeCanvas = document.getElementById("feeChart");

        if (feeCanvas) {

        var feeCtx = feeCanvas.getContext("2d");

        new Chart(feeCtx, {
        type: 'line',
        data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
        datasets: [{
        label: 'Fee Collection',
        data: [
        @ViewBag.FeeJan,
        @ViewBag.FeeFeb,
        @ViewBag.FeeMar,
        @ViewBag.FeeApr,
        @ViewBag.FeeMay,
        @ViewBag.FeeJun,
        @ViewBag.FeeJul,
        @ViewBag.FeeAug,
        @ViewBag.FeeSep,
        @ViewBag.FeeOct,
        @ViewBag.FeeNov,
        @ViewBag.FeeDec
        ],
        borderColor: '#198754',
        backgroundColor: 'rgba(25,135,84,0.2)',
        fill: true,
        tension: 0.4
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false
        }
        });

        }

        // ===========================
        // Course Wise Chart
        // ===========================
        const courseCanvas = document.getElementById("courseChart");

        if (courseCanvas) {

        var courseCtx = courseCanvas.getContext("2d");

        new Chart(courseCtx, {
        type: 'pie',
        data: {
        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CourseNames)),
        datasets: [{
        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CourseCounts)),
        backgroundColor: [
        '#0d6efd',
        '#198754',
        '#ffc107',
        '#dc3545',
        '#6f42c1',
        '#20c997',
        '#fd7e14',
        '#6610f2'
        ]
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: {
        position: 'bottom'
        }
        }
        }
        });

        }

        });
    </script>

}
